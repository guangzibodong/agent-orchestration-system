NODE_ENV=production

# Active API/web settings.
# For local-only development, change API_HOST to 127.0.0.1.
API_HOST=0.0.0.0
API_PORT=4000
MAWO_STATE_BACKEND=file
MAWO_QUEUE_BACKEND=in_process
MAWO_MAX_CONCURRENT_JOBS=1
MAWO_API_REPLICA_COUNT=1
MAWO_API_TOKEN=
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
NEXT_PUBLIC_REPOSITORY_PATH=
MAWO_ALLOWED_REPOSITORY_ROOTS=

# Optional real CLI agent command templates. Leave empty for demo/fake agent only.
MAWO_CODEX_COMMAND_TEMPLATE=
MAWO_CODEX_AUTH_PROBE_COMMAND=
MAWO_CLAUDE_COMMAND_TEMPLATE=
MAWO_CLAUDE_AUTH_PROBE_COMMAND=
MAWO_CURSOR_COMMAND_TEMPLATE=
MAWO_CURSOR_AUTH_PROBE_COMMAND=

# Optional Postgres state backend. Set MAWO_STATE_BACKEND=postgres after migrations.
# Queue execution is still in-process by default; worker:postgres can claim jobs
# from Postgres for the external worker path, and REDIS_URL is reserved for the
# future Redis queue.
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://mawo:<postgres-password>@localhost:5432/mawo?schema=public
REDIS_URL=redis://localhost:6379
MAWO_WORKER_ID=
MAWO_WORKER_ONCE=
MAWO_WORKER_POLL_MS=1000
MAWO_WORKER_LEASE_MS=300000
MAWO_WORKER_RENEW_INTERVAL_MS=60000
